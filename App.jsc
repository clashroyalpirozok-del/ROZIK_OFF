import React, { useEffect, useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import axios from 'axios';
import './BrawlStyle.css';

// ТВОЙ API КЛЮЧ
const API_KEY = 'eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzUxMiIsImtpZCI6IjI4YTMxOGY3LTAwMDAtYTFlYi03ZmExLTJjNzQzM2M2Y2NhNSJ9..Qo6NXjK_XAn2G_lKJl5DqDokvmvL1C2Hu_XCW8dDeimwRBf986obeBM3GcCQseQZDUi65MhV1M6xerNgw_bWRw';

// 👇 ТВОЙ КЛУБ
const CLUB_TAG = '#29QLUYOPO';

function App() {
  const [club, setClub] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(false);

  const fetchClub = async () => {
    try {
      setLoading(true);
      setError(false);
      const cleanTag = CLUB_TAG.replace('#', '');
      
      const response = await axios.get(
        `https://bsproxy.royaleapi.dev/v1/clubs/%23${cleanTag}`,
        { 
          headers: { 
            'Authorization': `Bearer ${API_KEY}` 
          } 
        }
      );
      setClub(response.data);
      createCelebration();
    } catch (error) {
      console.error('Ошибка:', error);
      setError(true);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchClub();
    const interval = setInterval(fetchClub, 30000);
    return () => clearInterval(interval);
  }, []);

  const createCelebration = () => {
    for (let i = 0; i < 20; i++) {
      const star = document.createElement('div');
      star.className = 'brawl-star';
      star.style.left = Math.random() * 100 + '%';
      star.style.top = Math.random() * 100 + '%';
      star.style.animationDelay = Math.random() * 2 + 's';
      document.body.appendChild(star);
      setTimeout(() => star.remove(), 3000);
    }
  };

  if (error) {
    return (
      <div className="brawl-container">
        <motion.div initial={{ scale: 0.9 }} animate={{ scale: 1 }} className="error-card">
          <h2>😱 КЛУБ НЕ НАЙДЕН</h2>
          <p>Проверь тег клуба: {CLUB_TAG}</p>
          <button className="brawl-button" onClick={fetchClub}>🔄 ПОВТОРИТЬ</button>
        </motion.div>
      </div>
    );
  }

  if (loading) {
    return (
      <div className="brawl-container">
        <motion.div animate={{ rotate: 360 }} transition={{ repeat: Infinity, duration: 1 }} className="brawl-loader" />
        <p style={{ color: '#fff', marginTop: 20 }}>Загрузка клуба...</p>
      </div>
    );
  }

  return (
    <div className="brawl-container">
      <motion.div initial={{ y: -50, opacity: 0 }} animate={{ y: 0, opacity: 1 }} className="club-header">
        <h1 className="club-name">⚔️ {club.name}</h1>
        <p className="club-tag">#{club.tag}</p>
        <div className="club-stats">
          <span>🏆 {club.trophies}</span>
          <span>👥 {club.members?.length || 0}</span>
          <span>🏅 {club.requiredTrophies}+</span>
        </div>
      </motion.div>

      <div className="members-list">
        <h3 style={{ color: '#f5a623', marginBottom: 15 }}>🔥 БОЙЦЫ КЛУБА</h3>
        <AnimatePresence>
          {club.members?.map((member, index) => (
            <motion.div
              key={member.tag}
              initial={{ opacity: 0, x: -100 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 100 }}
              transition={{ delay: index * 0.05, type: 'spring' }}
              whileHover={{ scale: 1.02 }}
              className="member-card"
            >
              <motion.img
                whileHover={{ rotate: 360 }}
                transition={{ duration: 0.5 }}
                src={`https://cdn.brawlstats.com/avatars/${member.avatarId || 0}.png`}
                className="member-avatar"
                onError={(e) => { e.target.src = 'https://cdn.brawlstats.com/avatars/0.png'; }}
              />
              <div className="member-info">
                <div className="member-name">{member.name}</div>
                <div className="member-role">
                  {member.role === 'president' && '👑 Президент'}
                  {member.role === 'vicePresident' && '⚡ Вице-президент'}
                  {member.role === 'senior' && '⭐ Старший'}
                  {member.role === 'member' && '🎯 Боец'}
                </div>
                <div className="member-trophies">🏆 {member.trophies}</div>
              </div>
              <motion.div
                animate={{ scale: [1, 1.3, 1], opacity: [0.5, 1, 0.5] }}
                transition={{ repeat: Infinity, duration: 2, delay: index * 0.1 }}
                className="online-dot"
              />
            </motion.div>
          ))}
        </AnimatePresence>
      </div>

      <motion.button
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        whileHover={{ scale: 1.05 }}
        whileTap={{ scale: 0.95 }}
        className="refresh-btn"
        onClick={fetchClub}
      >
        🔄 ОБНОВИТЬ
      </motion.button>
    </div>
  );
}

export default App;
